# === Claude API (optional — enables LLM Executive Summary) ===
ANTHROPIC_API_KEY=sk-ant-...
# Defaults to claude-opus-4-7 (Anthropic-recommended).
# Override to claude-sonnet-4-6 / claude-haiku-4-5 to trade quality for cost.
ANTHROPIC_MODEL=claude-opus-4-7

# === Korea Investment Securities OpenAPI (optional — enables realtime KR indices) ===
# Signup: https://apiportal.koreainvestment.com/
# Leave blank to use Yahoo Finance (~15-min delay) for KOSPI/KOSDAQ.
KIS_APP_KEY=
KIS_APP_SECRET=
# 'real' for 실전투자, 'vts' for 모의투자
KIS_ENV=real
